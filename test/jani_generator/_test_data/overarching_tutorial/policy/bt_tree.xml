<root BTCPP_format="4">
    <BehaviorTree ID="MainTree">
        <Sequence>
            <NavigateToLocation name="navigate_to_obj" location="fridge" />
            <RetryUntilSuccessful name="retry_detect_obj" num_attempts="3">
                <DetectObject name="detect_obj" object_id="{detected_obj_id}" />
            </RetryUntilSuccessful>
            <RetryUntilSuccessful name="retry_pick_obj" num_attempts="3">
                <PickObject name="pick_obj" object_id="{detected_obj_id}" />
            </RetryUntilSuccessful>
            <NavigateToLocation name="navigate_to_place" location="table" />
            <!-- <PlaceObject name="place_obj" object="butter" /> -->
            <RetryUntilSuccessful name="retry_place_obj" num_attempts="3">
                <ROS2Action name="place_action_skill" service_name_tick="/PlaceObjectSkill/tick"
                    service_name_halt="/PlaceObjectSkill/halt" interface="ROS2SERVICE"
                    isMonitored="false" />
            </RetryUntilSuccessful>
        </Sequence>

    </BehaviorTree>
</root>
