<!-- Test that the Parallel node fails when failure_threshold is met:
    - 3 children where 2 return success immediately, 1 return failure immediately
    - success_threshold = 3, failure_threshold = 1
    - Expected: Parallel returns FAILURE after 2 children fail
 -->
<root BTCPP_format="4" >
    <BehaviorTree ID="MainTree">
        <Parallel success_threshold="3" failure_threshold="1">
            <Action ID="AlwaysSuccess" />
            <Action ID="AlwaysFailure" />
            <Action ID="AlwaysSuccess" />
        </Parallel>
    </BehaviorTree>
</root>
