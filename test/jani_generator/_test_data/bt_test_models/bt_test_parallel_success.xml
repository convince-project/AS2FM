<!-- Test that the Parallel node succeeds when success_threshold is met:
    - 3 children where 2 return success immediately, 1 keeps returning running
    - success_threshold = 2, failure_threshold = 2
    - Expected: Parallel returns SUCCESS after 2 children succeed
 -->
<root BTCPP_format="4" >
    <BehaviorTree ID="MainTree">
        <Parallel success_threshold="2" failure_threshold="2">
            <Action ID="BtTestStatusAction" topic_name="tick_count_0" reset_name="reset_count_0" n_ticks_running="0" final_status="1" />
            <Action ID="BtTestStatusAction" topic_name="tick_count_1" reset_name="reset_count_1" n_ticks_running="0" final_status="1" />
            <Action ID="BtTestStatusAction" topic_name="tick_count_2" reset_name="reset_count_2" n_ticks_running="100" final_status="3" />
        </Parallel>
    </BehaviorTree>
</root>
